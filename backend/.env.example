# Copy to .env on the server and fill in real values. NEVER commit the real .env.

# Your DuckDNS domain (the one Caddy will get an HTTPS cert for)
DOMAIN=yourname.duckdns.org

# SQLite stored on the mounted /data volume (4 slashes = absolute path /data/bank101.db)
DATABASE_URL=sqlite:////data/bank101.db

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME

# Auth / JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

DEBUG=false
